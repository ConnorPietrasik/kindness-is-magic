POSTGRES_USER=replace_user
POSTGRES_PASSWORD=replace_pass
POSTGRES_DB=replace_db

# JWT secrets — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
REFRESH_SECRET_KEY=

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap admin (created on first startup if not present)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Set to "true" in development — insecure cookies, no rate limiting, dev-only behavior
DEBUG=false

# Invite code lifetime (hours) — default 336 = 14 days
INVITE_EXPIRY_HOURS=336

# Public-facing base URL (used for links in emails)
APP_BASE_URL=https://your-domain.com
